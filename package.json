{
  "name": "cloudchat",
  "version": "1.0.0",
  "description": "基于 Cloudflare 的开源聊天室",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply",
    "db:init": "wrangler d1 execute cloudchat --file ./migrations/001_init.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "hono": "^4.4.0",
    "jose": "^5.3.0",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.60.0"
  }
}
